{
  // ─── Formatting ──────────────────────────────────────────────────────────
  // Prettier is the single formatter for all file types (matches CI gate)
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[yaml]": { "editor.defaultFormatter": "redhat.vscode-yaml" },
  "[terraform]": { "editor.defaultFormatter": "hashicorp.terraform" },

  // ─── ESLint ──────────────────────────────────────────────────────────────
  // Auto-fix on save; validate .ts and .tsx (matches CI eslint config)
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit",
    "source.addMissingImports": "explicit"
  },
  "eslint.validate": ["javascript", "typescript", "typescriptreact", "javascriptreact"],

  // ─── TypeScript ──────────────────────────────────────────────────────────
  // Use the workspace TypeScript version (v6) not VS Code's bundled version
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.autoImports": true,

  // ─── Tailwind CSS ────────────────────────────────────────────────────────
  // Support class-variance-authority (CVA) and clsx used by shadcn/ui
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],

  // ─── Jest ────────────────────────────────────────────────────────────────
  // Per-project commands — jest-runner picks the entry whose projectPath
  // is the closest ancestor of the file being run.
  "jestrunner.projects": [
    {
      "jestCommand": "pnpm --filter @ikaro/backend test",
      "projectPath": "${workspaceFolder}/apps/backend"
    },
    {
      "jestCommand": "pnpm --filter @ikaro/bff test",
      "projectPath": "${workspaceFolder}/apps/bff"
    }
  ],
  // Restrict Run|Debug code lens to spec/test files — keeps migrations clean
  "jestrunner.codeLensSelector": "**/*.{spec,test}.{js,jsx,ts,tsx}",

  // ─── Coverage gutters ────────────────────────────────────────────────────
  // lcov report generated by pnpm --filter @ikaro/backend test:cov
  "coverage-gutters.lcovname": "lcov.info",
  "coverage-gutters.showLineCoverage": true,
  "coverage-gutters.coverageBaseDir": "apps/backend/coverage",

  // ─── SonarLint ───────────────────────────────────────────────────────────
  // Connected mode mirrors the SonarCloud project used in CI
  // To activate: install SonarLint → F1 → "SonarLint: Connect to SonarCloud"
  "sonarlint.connectedMode.connections.sonarcloud": [
    {
      "organizationKey": "lmmoreira",
      "connectionId": "ikaro-sonarcloud"
    }
  ],
  "sonarlint.connectedMode.project": {
    "connectionId": "ikaro-sonarcloud",
    "projectKey": "lmmoreira_ikaro"
  },

  // ─── File explorer ───────────────────────────────────────────────────────
  // Hide build artefacts and generated files from the explorer tree
  "files.exclude": {
    "**/.next": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.scannerwork": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/coverage": true,
    "**/pnpm-lock.yaml": true
  },

  // ─── File associations ───────────────────────────────────────────────────
  "files.associations": {
    "*.env.example": "properties",
    "Dockerfile*": "dockerfile"
  },

  // ─── REST Client (HTTP files) ────────────────────────────────────────────
  // Reads PLATFORM_ADMIN_KEY from the gitignored apps/backend/.env automatically.
  // Install extension: humao.rest-client  →  select "local" in the VS Code status bar.
  //
  // QUICK-START WORKFLOW (run once per dev session):
  //   1. pnpm infra:up
  //   2. pnpm --filter @ikaro/backend run migration:run
  //   3. pnpm --filter @ikaro/backend run seed
  //   4. pnpm --filter @ikaro/backend run dev      (port 3001)
  //   5. pnpm --filter @ikaro/bff run dev          (port 3002)  +  ENABLE_DEV_AUTH=true in apps/bff/.env.local
  //   6. Open apps/bff/http/auth/dev-login.http
  //      Run the 3 login requests (managerLogin / staffLogin / customerLogin).
  //      Paste each accessToken below into managerToken / staffToken / customerToken.
  //      Tokens last 7 days — refresh weekly.
  //
  // SEED DATA REFERENCE (src/shared/database/seed.ts — all idempotent UUIDs):
  //   Tenant A  →  lavacar-beloauto   (tenantId)
  //   Tenant B  →  autospa-premium    (tenantBId)
  //   Manager   →  admin@lavacar.com.br        (managerId)
  //   Staff     →  funcionario@lavacar.com.br  (staffWorkerId)
  //   Customer  →  cliente@email.com.br        (customerId)
  //   Services  →  Simples(serviceId) / Completa(service2Id) / Polimento(service3Id) / Higienizacao(service4Id)
  //   Bookings  →  PENDING(bookingId) / APPROVED(approvedBookingId) / COMPLETED(completedBookingId)
  //   Lines     →  completedBookingId line (bookingLineId) — 10 pts, Lavagem Completa
  "rest-client.dotenv.path": "${workspaceFolder}/apps/backend/.env",
  "rest-client.defaultHeaders": {
    "Content-Type": "application/json"
  },
