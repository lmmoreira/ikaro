  // ─── Editor ──────────────────────────────────────────────────────────────
  // 100-char ruler matches prettier printWidth; 2-space indent throughout
  "editor.rulers": [100],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.linkedEditing": true
}
