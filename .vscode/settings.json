{
  // ─── Formatting ──────────────────────────────────────────────────────────
  // Prettier is the single formatter for all file types (matches CI gate)
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[yaml]": { "editor.defaultFormatter": "redhat.vscode-yaml" },
  "[terraform]": { "editor.defaultFormatter": "hashicorp.terraform" },

  // ─── ESLint ──────────────────────────────────────────────────────────────
  // Auto-fix on save; validate .ts and .tsx (matches CI eslint config)
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit",
    "source.addMissingImports": "explicit"
  },
  "eslint.validate": ["javascript", "typescript", "typescriptreact", "javascriptreact"],

  // ─── TypeScript ──────────────────────────────────────────────────────────
  // Use the workspace TypeScript version (v6) not VS Code's bundled version
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.autoImports": true,

  // ─── Tailwind CSS ────────────────────────────────────────────────────────
  // Support class-variance-authority (CVA) and clsx used by shadcn/ui
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],

  // ─── Jest ────────────────────────────────────────────────────────────────
  // Point jest-runner at the backend workspace
  "jestrunner.jestCommand": "pnpm --filter @beloauto/backend test",
  "jestrunner.projectPath": "apps/backend",
  // Restrict Run|Debug code lens to spec/test files — keeps migrations clean
  "jestrunner.codeLensSelector": "**/*.{spec,test}.{js,jsx,ts,tsx}",

  // ─── Coverage gutters ────────────────────────────────────────────────────
  // lcov report generated by pnpm --filter @beloauto/backend test:cov
  "coverage-gutters.lcovname": "lcov.info",
  "coverage-gutters.showLineCoverage": true,
  "coverage-gutters.coverageBaseDir": "apps/backend/coverage",

  // ─── SonarLint ───────────────────────────────────────────────────────────
  // Connected mode mirrors the SonarCloud project used in CI
  // To activate: install SonarLint → F1 → "SonarLint: Connect to SonarCloud"
  "sonarlint.connectedMode.connections.sonarcloud": [
    {
      "organizationKey": "lmmoreira",
      "connectionId": "beloauto-sonarcloud"
    }
  ],
  "sonarlint.connectedMode.project": {
    "connectionId": "beloauto-sonarcloud",
    "projectKey": "lmmoreira_beloauto"
  },

  // ─── File explorer ───────────────────────────────────────────────────────
  // Hide build artefacts and generated files from the explorer tree
  "files.exclude": {
    "**/.next": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.scannerwork": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/coverage": true,
    "**/pnpm-lock.yaml": true
  },

  // ─── File associations ───────────────────────────────────────────────────
  "files.associations": {
    "*.env.example": "properties",
    "Dockerfile*": "dockerfile"
  },

  // ─── Editor ──────────────────────────────────────────────────────────────
  // 100-char ruler matches prettier printWidth; 2-space indent throughout
  "editor.rulers": [100],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.linkedEditing": true
}
