{
  "name": "ikaro",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "postinstall": "pnpm --filter @ikaro/i18n build && pnpm --filter @ikaro/observability build && pnpm --filter @ikaro/env-validation build",
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "up": "pnpm infra:up && pnpm dev",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r --parallel run type-check",
    "format": "pnpm -r run format",
    "test:e2e": "pnpm --filter @ikaro/web run e2e",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "obs:up": "docker compose -f docker/docker-compose.observability.yml up -d",
    "db:migrate": "pnpm --filter @ikaro/backend migration:run",
    "db:revert": "pnpm --filter @ikaro/backend migration:revert",
    "db:seed": "pnpm --filter @ikaro/backend seed",
    "fix": "pnpm prettier --write . && pnpm -r run lint --fix",
    "pre-pr": "bash scripts/pre-pr.sh",
    "ci:fast": "pnpm lint && pnpm prettier --check . && pnpm type-check && pnpm --filter @ikaro/backend test:unit && pnpm --filter @ikaro/bff test && pnpm --filter @ikaro/web test",
    "ci:integration": "pnpm --filter @ikaro/backend test:integration && pnpm --filter @ikaro/bff test:component",
    "ci:local": "bash scripts/ci-local.sh"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "wait-on": "^8.0.3"
  }
}
