{
  "name": "beloauto",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "up": "pnpm infra:up && pnpm dev",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "format": "pnpm -r run format",
    "test:e2e": "pnpm --filter @beloauto/web run test:e2e",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "obs:up": "docker compose -f docker/docker-compose.observability.yml up -d",
    "db:migrate": "pnpm --filter @beloauto/backend migration:run",
    "db:revert": "pnpm --filter @beloauto/backend migration:revert",
    "db:seed": "pnpm --filter @beloauto/backend seed",
    "fix": "pnpm prettier --write . && pnpm -r run lint --fix",
    "pre-pr": "bash scripts/pre-pr.sh",
    "ci:fast": "pnpm lint && pnpm prettier --check . && pnpm type-check && pnpm --filter @beloauto/backend test:unit && pnpm --filter @beloauto/bff test && pnpm --filter @beloauto/web test",
    "ci:integration": "pnpm --filter @beloauto/backend test:integration && pnpm --filter @beloauto/bff test:component",
    "ci:local": "bash scripts/ci-local.sh"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "@grpc/grpc-js": "1.14.4",
      "form-data": "4.0.6",
      "protobufjs": "7.6.1"
    }
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
