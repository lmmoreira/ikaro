NODE_ENV=development
APP_ENV=local
PORT=3002
LOG_LEVEL=DEBUG
LOG_VENDOR=gcp
# Optional: enables Cloud Logging trace correlation fields when a span is active.
# GCP_PROJECT=ikaro-staging

# Backend internal URL (no public exposure)
BACKEND_INTERNAL_URL=http://localhost:3001

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string-in-production-environments
JWT_EXPIRES_IN=7d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/v1/auth/google/callback

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Frontend app URL (used for OAuth redirects after login)
FRONTEND_URL=http://localhost:3000

# Dev-only OAuth bypass — enables POST /v1/auth/dev-login for local testing without Google OAuth
# Set to true in .env (local dev only). Staging is allowed for E2E; startup fails in production.
# ENABLE_DEV_AUTH=true

# Internal API key — shared secret between BFF and backend (generate with: openssl rand -hex 32)
# Must be identical in both apps/backend/.env and apps/bff/.env
INTERNAL_API_KEY=change-me-generate-with-openssl-rand-hex-32

# Backend Cloud Run IAM authentication (M17-S47) — "none" for local dev (default).
# "iam" is required whenever NODE_ENV=production (both staging and prod cloud
# builds set NODE_ENV=production); startup fails otherwise. In "iam" mode the
# BFF attaches a Google-signed ID token to every backend request, on top of
# (not instead of) INTERNAL_API_KEY above.
BACKEND_AUTH_MODE=none
# Audience for the ID token — defaults to BACKEND_INTERNAL_URL if unset.
# BACKEND_AUDIENCE=

# OpenTelemetry SDK bootstrap (M17-S33) — traces only, OTLP-HTTP only
# Endpoint of the OTel collector sidecar (M17-S34); local dev leaves this unset unless the
# `pnpm obs` profile is running a local collector on this port.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Sampling ratio (0.0-1.0) — set per environment: staging 1.0, production 0.1. Read directly,
# never derived from NODE_ENV/APP_ENV (see tracing.ts).
# OTEL_TRACES_SAMPLER_ARG=1.0
# Resource service.name attribute. Defaults to "ikaro-bff" if unset.
# SERVICE_NAME=ikaro-bff
# Overrides whether the OTel SDK starts. Defaults to disabled when APP_ENV=local (this app's
# default — see above) and enabled for staging/production, so you normally never need to set
# this locally. Set to "true"/"false" to force it either direction — e.g. "false" here to test
# against a local collector via the `pnpm obs` profile.
# OTEL_SDK_DISABLED=false
