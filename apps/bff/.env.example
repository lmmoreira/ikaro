NODE_ENV=development
PORT=3002

# Backend internal URL (no public exposure)
BACKEND_INTERNAL_URL=http://localhost:3001

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string-in-production-environments
JWT_EXPIRES_IN=7d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/v1/auth/google/callback

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Frontend app URL (used for OAuth redirects after login)
FRONTEND_URL=http://localhost:3000

# Cron endpoint protection
CRON_SECRET=change-me-to-a-random-32-char-string-for-cron-endpoints
