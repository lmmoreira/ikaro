# BFF — Platform endpoints (public)
# M12-S01: Hotsite manifest — used by the Next.js hotsite renderer
#
# Prerequisites:
#   1. pnpm infra:up
#   2. pnpm --filter @ikaro/backend run migration:run
#   3. pnpm --filter @ikaro/backend run dev
#   4. pnpm --filter @ikaro/bff run dev
#
# REST Client environment: select "local" in VS Code status bar

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH
# ─────────────────────────────────────────────────────────────────────────────

### Get the hotsite manifest for a tenant by slug (public — no auth required)
GET {{bffUrl}}/v1/public/platform/manifest/{{tenantSlug}}

# ─────────────────────────────────────────────────────────────────────────────
# ERROR CASES
# ─────────────────────────────────────────────────────────────────────────────

### 404 — Unknown tenant slug
GET {{bffUrl}}/v1/public/platform/manifest/no-such-tenant-slug

###

### 404 — Hotsite exists but is not published
GET {{bffUrl}}/v1/public/platform/manifest/unpublished-hotsite-tenant

# ─────────────────────────────────────────────────────────────────────────────
# Published hotsites listing (M12-S09 — backs apps/web sitemap.xml)
# ─────────────────────────────────────────────────────────────────────────────

### List active tenants with a published hotsite — { items: [{ slug, updatedAt }] }
GET {{bffUrl}}/v1/public/platform/published-hotsites
