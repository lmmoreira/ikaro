# BFF — Services endpoints
# UC-012 (create), UC-013 (update, deactivate), public list
#
# Prerequisites:
#   1. pnpm infra:up
#   2. pnpm --filter @beloauto/backend run migration:run
#   3. pnpm --filter @beloauto/backend run dev
#   4. pnpm --filter @beloauto/bff run dev
#
# REST Client environment: select "local" in VS Code status bar

@bffUrl = {{bffUrl}}
@serviceId = 10000000-0000-4000-8000-000000000001

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — list active services (public — no JWT required)
# ─────────────────────────────────────────────────────────────────────────────

###

### List active services for a tenant by slug (no auth required)
GET {{bffUrl}}/v1/services
X-Tenant-Slug: lavacar-bh

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — create service (UC-012)
# ─────────────────────────────────────────────────────────────────────────────

###

### Create a new service (MANAGER JWT required)
POST {{bffUrl}}/v1/services
Content-Type: application/json
Authorization: Bearer {{managerJwt}}

{
  "name": "Lavagem Completa",
  "description": "Lavagem exterior e interior completa",
  "priceAmount": 150,
  "durationMinutes": 60,
  "loyaltyPointsValue": 10,
  "requiresPickupAddress": false
}

###

### Create a service using STAFF role JWT
POST {{bffUrl}}/v1/services
Content-Type: application/json
Authorization: Bearer {{staffJwt}}

{
  "name": "Lavagem Domiciliar",
  "priceAmount": 200,
  "durationMinutes": 90,
  "loyaltyPointsValue": 15,
  "requiresPickupAddress": true
}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — update service (UC-013)
# ─────────────────────────────────────────────────────────────────────────────

###

### Update service name and price (partial update)
PATCH {{bffUrl}}/v1/services/{{serviceId}}
Content-Type: application/json
Authorization: Bearer {{managerJwt}}

{
  "name": "Lavagem Completa Premium",
  "priceAmount": 175
}

###

### Clear description (set to null)
PATCH {{bffUrl}}/v1/services/{{serviceId}}
Content-Type: application/json
Authorization: Bearer {{managerJwt}}

{
  "description": null
}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — deactivate service (UC-013)
# ─────────────────────────────────────────────────────────────────────────────

###

### Deactivate a service (logical delete)
DELETE {{bffUrl}}/v1/services/{{serviceId}}
Authorization: Bearer {{managerJwt}}

# ─────────────────────────────────────────────────────────────────────────────
# ERROR CASES
# ─────────────────────────────────────────────────────────────────────────────

###

### 400 — Missing X-Tenant-Slug on public list
GET {{bffUrl}}/v1/services

###

### 400 — Negative priceAmount (Zod validation at BFF)
POST {{bffUrl}}/v1/services
Content-Type: application/json
Authorization: Bearer {{managerJwt}}

{
  "name": "Lavagem Simples",
  "priceAmount": -50,
  "durationMinutes": 30,
  "loyaltyPointsValue": 5
}

###

### 403 — CUSTOMER JWT not allowed
POST {{bffUrl}}/v1/services
Content-Type: application/json
Authorization: Bearer {{customerJwt}}

{
  "name": "Lavagem Simples",
  "priceAmount": 80,
  "durationMinutes": 30,
  "loyaltyPointsValue": 5
}

###

### 409 — PATCH on deactivated service
PATCH {{bffUrl}}/v1/services/{{serviceId}}
Content-Type: application/json
Authorization: Bearer {{managerJwt}}

{
  "name": "Tentativa após desativação"
}
