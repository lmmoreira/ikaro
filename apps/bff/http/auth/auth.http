# BFF — Authentication (UC-021 / UC-022 / UC-023)
#
# Prerequisites:
#   1. Google OAuth credentials configured in GCP Console
#      (Authorized redirect URI: http://localhost:3002/v1/auth/google/callback)
#   2. pnpm infra:up  (PostgreSQL running)
#   3. pnpm --filter @ikaro/backend run migration:run
#   4. pnpm --filter @ikaro/backend run dev  (port 3001)
#   5. pnpm --filter @ikaro/bff run dev      (port 3002)
#   6. At least one tenant provisioned via apps/backend/http/platform/internal-tenants.http
#
# REST Client environment: select "local" in VS Code status bar.
# The OAuth callback (step 2 of the flow) must be completed in a browser —
# REST Client cannot follow Google's redirect chain.

# (all variables resolved directly from the "local" env — no file aliases needed)

# ─────────────────────────────────────────────────────────────────────────────
# STEP 1 — Open this URL in a browser (not REST Client)
# ─────────────────────────────────────────────────────────────────────────────

# ── UC-021: Customer login via a specific tenant's hotsite ──
# Browser URL (copy and paste):
# http://localhost:3002/v1/auth/google?tenantSlug=lavacar-beloauto
#
# Flow:
#   → BFF redirects to Google with state=lavacar-beloauto
#   → Google authenticates → redirects back to /v1/auth/google/callback
#   → BFF resolves tenant, finds or creates Customer, issues JWT
#   → Cookie access_token is set; browser redirects to FRONTEND_URL/{tenantSlug}
#
# First login creates the Customer record automatically (FindOrCreateCustomerUseCase).
# Subsequent logins return the same Customer (idempotent).

# ── UC-022: Staff login (already activated) ──
# Browser URL (copy and paste):
# http://localhost:3002/v1/auth/google?type=staff
#
# Flow:
#   → BFF redirects to Google with state=__staff__
#   → Google authenticates → redirects back to /v1/auth/google/callback
#   → BFF calls GET /internal/staff/by-oauth?googleOAuthId=<sub>
#   → Active staff found → issues JWT with role=STAFF|MANAGER, sets cookie, redirects to /dashboard
#   → Staff not found → redirects to /auth/error?reason=not-a-staff-member

# ── UC-025: Staff first login / accept invite ──
# Browser URL (copy and paste — from invite email link):
# http://localhost:3002/v1/auth/google?type=staff&tenantSlug=lavacar-beloauto
#
# Flow:
#   → BFF redirects to Google with state=__staff__:lavacar-beloauto
#   → Google authenticates → redirects back to /v1/auth/google/callback
#   → BFF: GET /internal/tenants/by-slug/lavacar-beloauto → tenantInfo
#   → BFF: GET /internal/staff/by-email?email=<google_email>&tenantId=<id>
#   → Staff found + isActive=true (no googleOAuthId yet) → POST /internal/staff/:staffId/link-google
#   → JWT issued → cookie set → redirects to /dashboard
#   → Staff deactivated → /auth/error?reason=staff-deactivated
#   → Email mismatch → /auth/error?reason=email-mismatch
#   → Not invited → /auth/error?reason=invite-not-found

# ── Logout (hotsite auth bar "Sair" — M13-S42) ──
# Browser URL (copy and paste):
# http://localhost:3002/v1/auth/logout?tenantSlug=lavacar-beloauto
#
# Flow:
#   → BFF clears the access_token cookie
#   → Redirects to FRONTEND_URL/lavacar-beloauto
#
# Omitting ?tenantSlug (or passing an invalid slug) redirects to bare FRONTEND_URL instead.

# ─────────────────────────────────────────────────────────────────────────────
# UC-023: Customer switches tenant — POST /v1/auth/switch-tenant
# Requires: valid JWT with role=CUSTOMER (access_token cookie or Bearer header)
# (Login-time multi-tenant selection — POST /v1/auth/token — was removed: no shipped UI
#  ever reaches it. See docs/04-USE_CASES.md UC-021.)
# ─────────────────────────────────────────────────────────────────────────────

### Switch to a different tenant the customer belongs to
POST {{bffUrl}}/v1/auth/switch-tenant
Content-Type: application/json
Authorization: Bearer paste-customer-jwt-here

{
  "targetTenantId": "paste-target-tenant-uuid-here"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# MULTI-TENANT STAFF SELECTION — GET /v1/auth/staff-tenants + POST /v1/auth/staff-token
# UC-022 (staff in 2+ tenants): after browser redirects to /select-staff-tenant?token=<...>,
# the frontend GETs the list then POSTs to exchange the selection token for a JWT.
# ─────────────────────────────────────────────────────────────────────────────

### List tenants where the staff member has an active record (multi-tenant selection)
# Replace token with the value from the ?token= query param in the redirect URL
GET {{bffUrl}}/v1/auth/staff-tenants?token=paste-selection-token-here

###

### Exchange staff selection token for JWT
POST {{bffUrl}}/v1/auth/staff-token
Content-Type: application/json

{
  "selectionToken": "paste-selection-token-here",
  "staffId": "paste-target-staff-uuid-here"
}

###

### 400 — Selection token missing or invalid for staff-tenants
GET {{bffUrl}}/v1/auth/staff-tenants?token=invalid.token.signature

###

### 400 — selectionToken missing from staff-token body
POST {{bffUrl}}/v1/auth/staff-token
Content-Type: application/json

{
  "staffId": "{{staffId}}"
}

###

### 403 — staffId not in the selection token's tenant list (or inactive)
POST {{bffUrl}}/v1/auth/staff-token
Content-Type: application/json

{
  "selectionToken": "paste-valid-selection-token-here",
  "staffId": "00000000-0000-4000-8000-000000009999"
}
