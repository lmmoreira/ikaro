# BFF — Loyalty endpoints (UC-016)
#
# Prerequisites:
#   1. pnpm infra:up
#   2. pnpm --filter @ikaro/backend run migration:run
#   3. pnpm --filter @ikaro/backend run dev   (port 3001)
#   4. pnpm --filter @ikaro/bff run dev       (port 3002)
#   5. ENABLE_DEV_AUTH=true in apps/bff/.env.local
#
# REST Client environment: select "local" in VS Code status bar

# ── File-level response captures (updated automatically when login request runs) ──
@managerToken  = {{managerLogin.response.body.accessToken}}
@customerToken = {{customerLogin.response.body.accessToken}}

# ── DEV AUTH — run each login once per session, then use the captured token ──

###
# @name managerLogin
POST {{bffUrl}}/v1/auth/dev-login
Content-Type: application/json

{ "email": "admin@lavacar.com.br", "tenantSlug": "{{tenantSlug}}", "type": "staff" }

###
# @name customerLogin
POST {{bffUrl}}/v1/auth/dev-login
Content-Type: application/json

{ "email": "cliente@email.com.br", "tenantSlug": "{{tenantSlug}}", "type": "customer" }

# ─────────────────────────────────────────────────────────────────────────────
# Customer views own balance / history
# ─────────────────────────────────────────────────────────────────────────────

###
### GET /v1/loyalty/balance — customer views own balance
# Returns CustomerLoyaltyBalanceResponse: { currentPoints, nextExpiryDate, nextExpiryPoints,
# conversionRate } — conversionRate is the live pointsPerCurrencyUnit from tenant settings
GET {{bffUrl}}/v1/loyalty/balance
Authorization: Bearer {{customerToken}}

###

### GET /v1/loyalty/entries — customer views earning history (M13-S08)
# Returns CustomerLoyaltyEntriesResponse: { items: [{ entryId, serviceName, pointsEarned,
# earnedAt, expiresAt, expired }], total, page, limit }
GET {{bffUrl}}/v1/loyalty/entries?page=1&limit=20
Authorization: Bearer {{customerToken}}

###

### GET /v1/loyalty/redemptions — customer views redemption history (M13-S08)
# Returns CustomerLoyaltyRedemptionsResponse: { items: [{ redemptionId, pointsUsed,
# amountSaved, redeemedAt, bookingReference }], total, page, limit }
# amountSaved is "R$ 0,00" when pointsPerCurrencyUnit is 0 (redemption disabled)
GET {{bffUrl}}/v1/loyalty/redemptions?page=1&limit=20
Authorization: Bearer {{customerToken}}

# ─────────────────────────────────────────────────────────────────────────────
# Admin views a customer's loyalty data
# ─────────────────────────────────────────────────────────────────────────────

###

### GET /v1/customers/:customerId/loyalty/balance — admin views customer balance
# Returns EnrichedLoyaltyBalanceResponse: { currentPoints, nextExpiryDate, nextExpiryPoints,
# conversionRate } — conversionRate from live tenant settings
GET {{bffUrl}}/v1/customers/{{customerId}}/loyalty/balance
Authorization: Bearer {{managerToken}}

###

### GET /v1/customers/:customerId/loyalty/entries — admin views customer earning history
GET {{bffUrl}}/v1/customers/{{customerId}}/loyalty/entries?page=1&limit=20
Authorization: Bearer {{managerToken}}

###

### GET /v1/customers/:customerId/loyalty/redemptions — admin views customer redemption history
GET {{bffUrl}}/v1/customers/{{customerId}}/loyalty/redemptions?page=1&limit=20
Authorization: Bearer {{managerToken}}

# ─────────────────────────────────────────────────────────────────────────────
# Admin redeems points on behalf of a customer
# ─────────────────────────────────────────────────────────────────────────────

###

### HAPPY PATH — redeem points (no booking or notes)
POST {{bffUrl}}/v1/loyalty/redeem
Content-Type: application/json
Authorization: Bearer {{managerToken}}

{
  "customerId": "{{customerId}}",
  "pointsToRedeem": 100
}

###

### HAPPY PATH — redeem points linked to a booking with notes
POST {{bffUrl}}/v1/loyalty/redeem
Content-Type: application/json
Authorization: Bearer {{managerToken}}

{
  "customerId": "{{customerId}}",
  "pointsToRedeem": 50,
  "bookingId": "{{completedBookingId}}",
  "notes": "Desconto aplicado no serviço de hoje"
}

###

### ERROR — pointsToRedeem less than 1 → 400
POST {{bffUrl}}/v1/loyalty/redeem
Content-Type: application/json
Authorization: Bearer {{managerToken}}

{
  "customerId": "{{customerId}}",
  "pointsToRedeem": 0
}

###

### ERROR — insufficient balance → 422
POST {{bffUrl}}/v1/loyalty/redeem
Content-Type: application/json
Authorization: Bearer {{managerToken}}

{
  "customerId": "{{customerId}}",
  "pointsToRedeem": 999999
}

###

### ERROR — no JWT → 401
POST {{bffUrl}}/v1/loyalty/redeem
Content-Type: application/json

{
  "customerId": "{{customerId}}",
  "pointsToRedeem": 100
}

###

### ERROR — customer JWT (wrong role) → 403
POST {{bffUrl}}/v1/loyalty/redeem
Content-Type: application/json
Authorization: Bearer {{customerToken}}

{
  "customerId": "{{customerId}}",
  "pointsToRedeem": 100
}
