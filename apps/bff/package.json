{
  "name": "@beloauto/bff",
  "version": "0.0.1",
  "private": true,
  "description": "BeloAuto NestJS Backend-for-Frontend service",
  "scripts": {
    "dev": "ts-node --swc -r tsconfig-paths/register src/main.ts",
    "build": "swc src -d dist --strip-leading-paths",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "echo \"No tests yet\""
  },
  "devDependencies": {
    "@beloauto/config": "workspace:*",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "@beloauto/types": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  }
}
