{
  "name": "@ikaro/bff",
  "version": "0.0.1",
  "private": true,
  "description": "Ikaro NestJS Backend-for-Frontend service",
  "scripts": {
    "dev": "ts-node --swc -r tsconfig-paths/register src/main.ts",
    "build": "swc src -d dist --strip-leading-paths",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns='component\\.spec\\.ts'",
    "test:component": "jest --testPathPatterns='component\\.spec\\.ts'",
    "test:cov": "jest --coverage --testPathIgnorePatterns='component\\.spec\\.ts'"
  },
  "devDependencies": {
    "@ikaro/config": "workspace:*",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.9.4",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "@ikaro/env-validation": "workspace:*",
    "@ikaro/nestjs-http": "workspace:*",
    "@ikaro/observability": "workspace:*",
    "@ikaro/types": "workspace:*",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/throttler": "^6.5.0",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  }
}
