NODE_ENV=development

# BFF base URL (called from the browser)
NEXT_PUBLIC_BFF_URL=http://localhost:3002/v1

# Hotsite public image bucket base URL (fake-gcs-server in local dev)
NEXT_PUBLIC_HOTSITE_IMAGE_BASE_URL=http://localhost:4443/beloauto-local-public

# Shared secret for the on-demand ISR revalidation endpoint (/api/revalidate)
# Must be ≥32 chars. Same value must be set in the backend HOTSITE_REVALIDATE_SECRET.
HOTSITE_REVALIDATE_SECRET=change-me-to-a-random-32-char-string
