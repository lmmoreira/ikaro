NODE_ENV=development

# BFF base URL (called from the browser)
NEXT_PUBLIC_BFF_URL=http://localhost:3002/v1

# Hotsite public image bucket base URL (fake-gcs-server in local dev)
NEXT_PUBLIC_HOTSITE_IMAGE_BASE_URL=http://localhost:4443/ikaro-local-public

# Shared secret for the on-demand ISR revalidation endpoint (/api/revalidate)
# Must be ≥32 chars. Same value must be set in the backend HOTSITE_REVALIDATE_SECRET.
HOTSITE_REVALIDATE_SECRET=change-me-to-a-random-32-char-string

# Public base URL for this deployment — used to build canonical URLs, Open Graph tags,
# JSON-LD structured data, and sitemap.xml entries. https://<ikaro-domain> in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Verifies the signed guest info-request token on /bookings/:id/submit-info (M13-S38/S40).
# Same value must be set in the backend/BFF JWT_SECRET — it signs/verifies the same token.
JWT_SECRET=change-me-to-match-the-backend-and-bff-jwt-secret
