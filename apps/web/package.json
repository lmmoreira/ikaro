{
  "name": "@ikaro/web",
  "version": "0.0.1",
  "private": true,
  "description": "Ikaro Next.js 16 web application (hotsite + dashboard)",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"**/*.{ts,tsx}\" --no-error-on-unmatched-pattern",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:ci": "playwright test --reporter=list,html"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@ikaro/config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "axios-mock-adapter": "^2.1.0",
    "dotenv": "^17.4.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ikaro/i18n": "workspace:*",
    "@ikaro/types": "workspace:*",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.1",
    "react": "^19.2.7",
    "react-colorful": "^5.7.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  }
}
