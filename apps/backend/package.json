{
  "name": "@ikaro/backend",
  "version": "0.0.1",
  "private": true,
  "description": "Ikaro NestJS modular monolith backend",
  "scripts": {
    "dev": "ts-node --swc -r tsconfig-paths/register src/main.ts",
    "build": "swc src -d dist --strip-leading-paths",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --selectProjects integration",
    "test:cov": "jest --selectProjects unit --coverage",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/shared/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/shared/database/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/shared/database/data-source.ts",
    "migration:run:prod": "node node_modules/typeorm/cli.js migration:run -d dist/shared/database/data-source.js",
    "seed": "ts-node --swc -r tsconfig-paths/register src/shared/database/seed.ts"
  },
  "devDependencies": {
    "@ikaro/config": "workspace:*",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.2",
    "@types/node": "^25.9.4",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.1",
    "@google-cloud/storage": "^7.21.0",
    "@ikaro/env-validation": "workspace:*",
    "@ikaro/i18n": "workspace:*",
    "@ikaro/nestjs-http": "workspace:*",
    "@ikaro/observability": "workspace:*",
    "@ikaro/types": "workspace:*",
    "@ikaro/validation": "workspace:*",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.3",
    "cache-manager": "^7.2.9",
    "decimal.js": "^10.6.0",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.0.0",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  }
}
