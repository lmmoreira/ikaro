{
  "name": "@beloauto/backend",
  "version": "0.0.1",
  "private": true,
  "description": "BeloAuto NestJS modular monolith backend",
  "scripts": {
    "dev": "ts-node --swc -r tsconfig-paths/register src/main.ts",
    "build": "swc src -d dist --strip-leading-paths",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:cov": "jest --selectProjects unit --coverage",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/shared/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/shared/database/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/shared/database/data-source.ts",
    "seed": "ts-node --swc -r tsconfig-paths/register src/shared/database/seed.ts"
  },
  "devDependencies": {
    "@beloauto/config": "workspace:*",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.20",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "decimal.js": "^10.6.0",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.29",
    "uuid": "^9.0.1",
    "zod": "^4.4.3"
  }
}
