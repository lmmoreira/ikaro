NODE_ENV=development
# Deployment identity — distinguishes local dev from staging/production (both of which run
# NODE_ENV=production as a Docker build setting). Only 'local' relaxes push-guard enforcement below.
APP_ENV=local
PORT=3001
LOG_LEVEL=DEBUG
LOG_VENDOR=gcp
# Optional: enables Cloud Logging trace correlation fields when a span is active.
# GCP_PROJECT=ikaro-staging

# PostgreSQL — app runtime user (DML only: SELECT/INSERT/UPDATE/DELETE)
# The app connects with this user; it has no DDL privileges.
DB_HOST=localhost
DB_PORT=5432
DB_USER=ikaro_app
DB_PASSWORD=ikaro_app
DB_NAME=ikaro
# Keep small in Cloud Run to avoid exhausting Postgres connections across instances.
# Local default is intentionally higher; staging/prod should override to a lower value (for example 3).
DB_POOL_SIZE=10

# PostgreSQL — migration user (DDL: CREATE/ALTER/DROP schemas and tables)
# Used only by pnpm db:migrate (data-source.ts) — never loaded at app startup.
# In production these come from Secret Manager / CI environment; locally safe defaults are fine.
DB_MIGRATOR_USER=ikaro_migrator
DB_MIGRATOR_PASSWORD=ikaro_migrator

# Platform admin — generate with: openssl rand -hex 32
PLATFORM_ADMIN_KEY=change-me-generate-with-openssl-rand-hex-32

# Internal API key — shared secret between BFF and backend (generate with: openssl rand -hex 32)
# Must be identical in both apps/backend/.env and apps/bff/.env
INTERNAL_API_KEY=change-me-generate-with-openssl-rand-hex-32

# GCP Pub/Sub (emulator for local dev)
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=ikaro-local
# After this many nacks the adapter routes the message to the dead-letter topic
PUBSUB_MAX_DELIVERY_ATTEMPTS=5
# Must be false whenever APP_ENV != local — Terraform owns all Pub/Sub resources in staging/prod
# regardless of consumer mode; startup fails otherwise. true only for local dev.
PUBSUB_AUTO_CREATE=true
# pull = streaming pull (local dev, emulator); push = Pub/Sub POSTs to /pubsub/push (staging/prod)
PUBSUB_CONSUMER_MODE=pull
# Required when PUBSUB_CONSUMER_MODE=push — the exact /pubsub/push URL Pub/Sub's OIDC token targets
# PUBSUB_PUSH_AUDIENCE=https://ikaro-backend-xxxx.a.run.app/pubsub/push
# Required when PUBSUB_CONSUMER_MODE=push — the invoker service account Pub/Sub signs the OIDC token as
# PUBSUB_PUSH_SERVICE_ACCOUNT=ikaro-pubsub-invoker@<project>.iam.gserviceaccount.com
# PubSubPushGuard verifies the Google-signed OIDC token on /pubsub/push and /cron/* whenever
# APP_ENV != local — derived from APP_ENV, not a separate setting. Bypassed only when APP_ENV=local
# (the default), which lets you curl the endpoint locally with a hand-built envelope.

# GCS (fake-gcs-server for local dev)
GCS_EMULATOR_HOST=http://localhost:4443
GCS_BUCKET_NAME=ikaro-local
GCS_PUBLIC_BUCKET_NAME=ikaro-local-public
# Public asset base URL — pure template `${GCS_PUBLIC_BASE_URL}/${GCS_PUBLIC_BUCKET_NAME}/<path>`.
# Local dev points at fake-gcs-server's `-external-url`; prod uses the real public-bucket/CDN domain.
GCS_PUBLIC_BASE_URL=http://localhost:4443
# Path to service account JSON key — use fake-service-account.json for local dev / emulator
GCS_KEY_FILE=docker/fake-service-account.json
# Max upload size enforced via signed URL content-length-range condition (bytes; default 10 MB)
GCS_MAX_UPLOAD_BYTES=10485760

# Email / Notification
# EMAIL_ADAPTER=mailhog → uses MailHog (default for local dev; BREVO_SMTP_LOGIN/BREVO_SMTP_KEY not required)
# EMAIL_ADAPTER=brevo   → uses Brevo SMTP relay (staging/prod; BREVO_SMTP_LOGIN + BREVO_SMTP_KEY required)
# Startup fails when APP_ENV != local + EMAIL_ADAPTER=mailhog.
EMAIL_ADAPTER=mailhog
EMAIL_FROM=noreply@ikaro.example
SMTP_HOST=localhost
SMTP_PORT=1025
# BREVO_SMTP_LOGIN=your-brevo-account-login  # required only when EMAIL_ADAPTER=brevo
# BREVO_SMTP_KEY=xsmtpsib-xxxx                # required only when EMAIL_ADAPTER=brevo
# Brevo relay host/port/secure default to smtp-relay.brevo.com:465 (implicit TLS) —
# override only if that endpoint ever needs to change without a code deploy.
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=465
# BREVO_SMTP_SECURE=true

# JWT — must be at least 64 characters in every environment
JWT_SECRET=change-me-to-a-random-64-char-string-in-production-environments

# Frontend URL (used to build activation links in emails)
FRONTEND_URL=http://localhost:3000

# Hotsite revalidation — shared secret between backend and frontend (generate with: openssl rand -hex 32)
# Must be identical to HOTSITE_REVALIDATE_SECRET in apps/web/.env
HOTSITE_REVALIDATE_SECRET=change-me-generate-with-openssl-rand-hex-32

# Shared transactional outbox (TD24-S01) — shared.outbox relay config
OUTBOX_INLINE_DISPATCH_ENABLED=true
OUTBOX_SWEEP_BATCH_SIZE=100
OUTBOX_SWEEP_GRACE_SECONDS=30
OUTBOX_RETENTION_DAYS=14

# Shared inbox (TD24-S04) — consumer dedup retention; must stay >= 8 (Pub/Sub max redelivery is 7 days)
INBOX_RETENTION_DAYS=14

# OpenTelemetry SDK bootstrap (M17-S33) — traces only, OTLP-HTTP only
# Endpoint of the OTel collector sidecar (M17-S34); local dev leaves this unset unless the
# `pnpm obs` profile is running a local collector on this port.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Sampling ratio (0.0-1.0) — set per environment: staging 1.0, production 0.1. Read directly,
# never derived from NODE_ENV/APP_ENV (see tracing.ts).
# OTEL_TRACES_SAMPLER_ARG=1.0
# Resource service.name attribute. Defaults to "ikaro-backend" if unset.
# SERVICE_NAME=ikaro-backend
# Fully disables the OTel SDK — set true in CI/local when no collector is reachable, to skip
# background export-retry noise. Local dev/tests never load tracing.ts anyway (only `pnpm dev`/
# `pnpm start` do), so this mainly matters for Playwright E2E runs that boot the real process.
# OTEL_SDK_DISABLED=true
