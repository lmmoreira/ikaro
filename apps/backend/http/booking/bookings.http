PATCH {{baseUrl}}/bookings/{{bookingId}}/cancel-customer
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{customerId}}
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
X-Correlation-ID: test-corr-cancel-customer-001

###

# ERROR — booking not found → 404
PATCH {{baseUrl}}/bookings/00000000-0000-4000-8000-000000009999/cancel-customer
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{customerId}}
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
X-Correlation-ID: test-corr-cancel-customer-002

###

# ERROR — cancellation window expired (APPROVED booking within 48h) → 422
PATCH {{baseUrl}}/bookings/{{bookingId}}/cancel-customer
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{customerId}}
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
X-Correlation-ID: test-corr-cancel-customer-003

###

# ERROR — caller is not the booking owner → 403
PATCH {{baseUrl}}/bookings/{{bookingId}}/cancel-customer
X-Tenant-ID: {{tenantId}}
X-Actor-ID: 00000000-0000-4000-8000-000000009999
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
X-Correlation-ID: test-corr-cancel-customer-004

###

