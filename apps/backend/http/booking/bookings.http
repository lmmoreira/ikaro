Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-cancel-admin-003

{}

