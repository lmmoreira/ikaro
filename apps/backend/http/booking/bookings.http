# Booking — List, detail, guest & authenticated booking requests
# UC-001 (guest), UC-002 (authenticated customer)
# TenantContext is populated from X-Tenant-ID header (set by BFF).
#
# Prerequisites:
#   1. pnpm infra:up
#   2. pnpm --filter @beloauto/backend run migration:run
#   3. pnpm --filter @beloauto/backend run dev

@baseUrl = {{backendUrl}}
@tenantId = 10000000-0000-4000-8000-000000000001
@serviceId = 30000000-0000-4000-8000-000000000001
@customerId = 20000000-0000-4000-8000-000000000001
@staffId = 20000000-0000-4000-8000-000000000002
@bookingId = {{bookingId}}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — list all bookings for tenant (staff view)
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings?limit=25&offset=0
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-list-001

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — list with status filter
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings?status=PENDING&limit=25&offset=0
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-list-002

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — customer lists own bookings
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings?limit=25&offset=0
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{customerId}}
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
X-Correlation-ID: test-corr-list-003

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — get booking detail (staff)
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings/{{bookingId}}
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-detail-001

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — customer gets own booking detail
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings/{{bookingId}}
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{customerId}}
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
X-Correlation-ID: test-corr-detail-002

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — booking not found → 404
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings/00000000-0000-4000-8000-000000009999
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-detail-003

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — approve a PENDING booking (UC-003)
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/approve
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-approve-001

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — booking not found → 404
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/00000000-0000-4000-8000-000000009999/approve
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-approve-002

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — slot taken by another APPROVED booking → 409
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/approve
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-approve-003

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — invalid state transition (e.g. APPROVED → APPROVED) → 422
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/approve
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-approve-004

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — no role headers → 403
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/approve
X-Tenant-ID: {{tenantId}}
X-Correlation-ID: test-corr-approve-005

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — reject a PENDING booking (UC-004)
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/reject
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-reject-001

{
  "reason": "Service unavailable for the requested date"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — reason too short → 400
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/reject
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-reject-002

{
  "reason": "short"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — booking not found → 404
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/00000000-0000-4000-8000-000000009999/reject
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-reject-003

{
  "reason": "Service unavailable for the requested date"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — invalid state transition (e.g. APPROVED → REJECTED) → 422
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/reject
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-reject-004

{
  "reason": "Service unavailable for the requested date"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — request more info on a PENDING booking (UC-005a)
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/request-info
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-reqinfo-001

{
  "message": "Please provide clearer photos of the vehicle exterior"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — message too short (under 20 chars) → 400
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/request-info
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-reqinfo-002

{
  "message": "Too short"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — booking already INFO_REQUESTED → 422
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/{{bookingId}}/request-info
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-reqinfo-003

{
  "message": "Please provide clearer photos of the vehicle exterior"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — booking not found → 404
# ─────────────────────────────────────────────────────────────────────────────

PATCH {{baseUrl}}/bookings/00000000-0000-4000-8000-000000009999/request-info
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-reqinfo-004

{
  "message": "Please provide clearer photos of the vehicle exterior"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — guest booking (no pickup service)
# ─────────────────────────────────────────────────────────────────────────────

POST {{baseUrl}}/bookings
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Correlation-ID: test-corr-001

{
  "guestEmail": "joao@example.com",
  "guestName": "João Silva",
  "guestPhone": "31999999999",
  "guestAddress": {
    "street": "Rua das Acácias",
    "number": "45",
    "neighborhood": "Jardim América",
    "city": "Belo Horizonte",
    "state": "MG",
    "zipCode": "30130020"
  },
  "scheduledAt": "2026-06-15T13:00:00.000Z",
  "serviceIds": ["{{serviceId}}"]
}

###

