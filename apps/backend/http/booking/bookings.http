# Booking — List, detail, guest & authenticated booking requests
# UC-001 (guest), UC-002 (authenticated customer)
# TenantContext is populated from X-Tenant-ID header (set by BFF).
#
# Prerequisites:
#   1. pnpm infra:up
#   2. pnpm --filter @ikaro/backend run migration:run
#   3. pnpm --filter @ikaro/backend run seed
#   4. pnpm --filter @ikaro/backend run dev
#
# Seed booking states:
#   bookingId          → PENDING   (approve / reject / request-info / cancel-customer)
#   approvedBookingId  → APPROVED  (reschedule / complete / cancel-admin)
#   completedBookingId → COMPLETED (error cases — already terminal)
# Note: state-changing operations consume the seed row; re-run seed to reset.

@baseUrl = {{backendUrl}}
@staffId = {{managerId}}
@lineId  = {{bookingLineId}}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — list all bookings for tenant (staff view)
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings?limit=25&offset=0
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-list-001

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — list with status filter
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings?status=PENDING&limit=25&offset=0
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-list-002

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — customer lists own bookings
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings?limit=25&offset=0
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{customerId}}
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
X-Correlation-ID: test-corr-list-003

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — get booking detail (staff)
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings/{{bookingId}}
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-detail-001

###

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — customer gets own booking detail
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings/{{bookingId}}
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{customerId}}
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
X-Correlation-ID: test-corr-detail-002

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR — booking not found → 404
# ─────────────────────────────────────────────────────────────────────────────

GET {{baseUrl}}/bookings/00000000-0000-4000-8000-000000009999
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-detail-003

###

