###
# ── Mark Booking Complete (UC-009) ─────────────────────────────────────────────
# Uses approvedBookingId (APPROVED state from seed).
# Replace lineId with the actual booking line ID — query GET /bookings/:id first
# or use a freshly created+approved booking with its own line IDs.

# SUCCESS — APPROVED → COMPLETED
PATCH {{baseUrl}}/bookings/{{approvedBookingId}}/complete
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-complete-001

{
  "lines": [
    { "lineId": "{{lineId}}", "actualPriceCharged": 80.00 }
  ],
  "afterServicePhotoUrls": ["tenants/{{tenantId}}/bookings/{{approvedBookingId}}/after1.jpg"],
  "adminNotes": "Extra shine applied"
}

###

# SUCCESS — APPROVED → COMPLETED with a loyalty points discount (UC-009 A6)
# Requires: booking.customerId != null, tenants.settings.loyalty.pointsPerCurrencyUnit > 0,
# amountDeducted = floor(pointsUsed / pointsPerCurrencyUnit), amountDeducted <= lines total.
PATCH {{baseUrl}}/bookings/{{approvedBookingId}}/complete
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{staffId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Correlation-ID: test-corr-complete-discount-001

{
  "lines": [
    { "lineId": "{{lineId}}", "actualPriceCharged": 100.00 }
  ],
  "afterServicePhotoUrls": [],
  "discountByPoints": { "pointsUsed": 200, "amountDeducted": 20.00 }
}

