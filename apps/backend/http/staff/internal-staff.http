# Staff — Internal Endpoints
# UC-022: BFF resolves which tenant a Google account belongs to (staff login)
# UC-025: BFF activates a staff member on first login (accept invite)
#
# Prerequisites:
#   1. pnpm infra:up           (start PostgreSQL + Pub/Sub emulator)
#   2. pnpm --filter @beloauto/backend run migration:run
#   3. pnpm --filter @beloauto/backend run dev
#
# REST Client environment: select "local" in VS Code status bar

@baseUrl = {{backendUrl}}
@sub = google-sub-example-staff-123
@tenantId = 10000000-0000-4000-8000-000000000001
@staffId = 10000000-0000-4000-8000-000000000099

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — invite staff (UC-028 / M04-S03)
# ─────────────────────────────────────────────────────────────────────────────

### Invite a new STAFF member
POST {{baseUrl}}/internal/staff/invite
Content-Type: application/json

{
  "tenantId": "{{tenantId}}",
  "email": "novo@lavacar.com.br",
  "firstName": "João",
  "lastName": "Silva",
  "role": "STAFF",
  "invitedBy": "{{staffId}}"
}

###

### Invite a new MANAGER
POST {{baseUrl}}/internal/staff/invite
Content-Type: application/json

{
  "tenantId": "{{tenantId}}",
  "email": "gerente2@lavacar.com.br",
  "firstName": "Maria",
  "lastName": "Costa",
  "role": "MANAGER",
  "invitedBy": "{{staffId}}"
}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — list staff (M04-S02)
# ─────────────────────────────────────────────────────────────────────────────

### List all staff for a tenant (default limit=50, offset=0)
GET {{baseUrl}}/internal/staff?tenantId={{tenantId}}

###

### List staff with explicit pagination
GET {{baseUrl}}/internal/staff?tenantId={{tenantId}}&limit=10&offset=0

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — get staff by id (M04-S02)
# ─────────────────────────────────────────────────────────────────────────────

###

### Get a specific staff member by id
GET {{baseUrl}}/internal/staff/{{staffId}}?tenantId={{tenantId}}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — by-oauth (UC-022)
# ─────────────────────────────────────────────────────────────────────────────

### Get staff info for a known active Google OAuth ID
GET {{baseUrl}}/internal/staff/by-oauth?googleOAuthId={{sub}}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — by-email (UC-025 first-login lookup)
# ─────────────────────────────────────────────────────────────────────────────

###

### Find invited (inactive) staff by email + tenantId
GET {{baseUrl}}/internal/staff/by-email?email=gerente@lavacar.com.br&tenantId={{tenantId}}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH — activate (UC-025)
# ─────────────────────────────────────────────────────────────────────────────

###

### Activate staff on first Google login
POST {{baseUrl}}/internal/staff/{{staffId}}/activate
Content-Type: application/json

{
  "tenantId": "{{tenantId}}",
  "googleOAuthId": "{{sub}}",
  "email": "gerente@lavacar.com.br"
}

# ─────────────────────────────────────────────────────────────────────────────
# ERROR CASES
# ─────────────────────────────────────────────────────────────────────────────

###

# ─────────────────────────────────────────────────────────────────────────────
# ERROR CASES — invite (UC-028 / M04-S03)
# ─────────────────────────────────────────────────────────────────────────────

###

### 409 — Email already active in the same tenant
POST {{baseUrl}}/internal/staff/invite
Content-Type: application/json

{
  "tenantId": "{{tenantId}}",
  "email": "gerente@lavacar.com.br",
  "firstName": "João",
  "lastName": "Silva",
  "role": "STAFF",
  "invitedBy": "{{staffId}}"
}

###

### 400 — Missing required fields (no firstName/lastName/role)
POST {{baseUrl}}/internal/staff/invite
Content-Type: application/json

{
  "tenantId": "{{tenantId}}",
  "email": "novo@lavacar.com.br"
}

###

### 400 — Invalid email format
POST {{baseUrl}}/internal/staff/invite
Content-Type: application/json

{
  "tenantId": "{{tenantId}}",
  "email": "not-an-email",
  "firstName": "João",
  "lastName": "Silva",
  "role": "STAFF",
  "invitedBy": "{{staffId}}"
}

# ─────────────────────────────────────────────────────────────────────────────
# ERROR CASES
# ─────────────────────────────────────────────────────────────────────────────

###

### 400 — Missing tenantId on list endpoint
GET {{baseUrl}}/internal/staff

###

### 404 — Staff id not found
GET {{baseUrl}}/internal/staff/10000000-0000-4000-8000-000000000099?tenantId={{tenantId}}

###

###

### 400 — Missing googleOAuthId query parameter
GET {{baseUrl}}/internal/staff/by-oauth

###

### 400 — Missing email or tenantId for by-email
GET {{baseUrl}}/internal/staff/by-email?tenantId={{tenantId}}

###

### 404 — Google account not registered as staff
GET {{baseUrl}}/internal/staff/by-oauth?googleOAuthId=unknown-sub-not-staff

###

### 404 — No staff with that email in this tenant
GET {{baseUrl}}/internal/staff/by-email?email=nobody@lavacar.com.br&tenantId={{tenantId}}

###

### 404 — staffId not found in tenant
POST {{baseUrl}}/internal/staff/non-existent-id/activate
Content-Type: application/json

{
  "tenantId": "{{tenantId}}",
  "googleOAuthId": "{{sub}}",
  "email": "gerente@lavacar.com.br"
}

###

### 422 — Google email does not match invited email
POST {{baseUrl}}/internal/staff/{{staffId}}/activate
Content-Type: application/json

{
  "tenantId": "{{tenantId}}",
  "googleOAuthId": "{{sub}}",
  "email": "wrong@gmail.com"
}
