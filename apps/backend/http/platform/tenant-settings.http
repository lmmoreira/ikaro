# Platform — Tenant Settings (settings JSONB only — see tenant.http for renaming the tenant)
# UC-026: Admin edits tenant settings
# Guarded by ManagerRoleGuard — requires X-Actor-Role: MANAGER on every request.
#
# Prerequisites:
#   1. pnpm infra:up
#   2. pnpm --filter @ikaro/backend run migration:run
#   3. pnpm --filter @ikaro/backend run seed
#   4. pnpm --filter @ikaro/backend run dev
#
# REST Client environment: select "local" in VS Code status bar

@baseUrl = {{backendUrl}}
@internalKey = {{$dotenv INTERNAL_API_KEY}}

# ─────────────────────────────────────────────────────────────────────────────
# HAPPY PATH
# ─────────────────────────────────────────────────────────────────────────────

### Get current tenant settings
GET {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER

###

### Partial loyalty update (only expiry_days changes; other loyalty fields preserved)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "loyalty": {
      "expiry_days": 365
    }
  }
}

###

### Partial booking update (only cancellation window; nothing else changes)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "booking": {
      "cancellation_window_hours": 72
    }
  }
}

###

### Update timezone and close Sunday
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_hours": {
      "timezone": "America/Manaus",
      "sunday": null
    }
  }
}

###

### Set business_info (phone, email, address) — used by the CONTACT hotsite module
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
X-Internal-Key: {{internalKey}}
Content-Type: application/json

{
  "settings": {
    "business_info": {
      "phone": "12982553850",
      "email": "contato@beloauto.com.br",
      "address": {
        "street": "Av. Paulista",
        "number": "1000",
        "complement": "Sala 12",
        "neighborhood": "Bela Vista",
        "city": "São Paulo",
        "state": "SP",
        "zip_code": "01310100"
      },
      "social_links": {
        "whatsapp": "12982553850",
        "instagram": "https://instagram.com/lavacar",
        "facebook": "https://facebook.com/lavacar"
      }
    }
  }
}

###

### Clear business_info.phone only (other business_info fields preserved)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_info": {
      "phone": null
    }
  }
}

###

### Clear business_info.address entirely
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_info": {
      "address": null
    }
  }
}

###

### Set social links (WhatsApp, Instagram, Facebook) — used by the CONTACT hotsite module
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_info": {
      "social_links": {
        "whatsapp": "11987654321",
        "instagram": "https://instagram.com/lavacar",
        "facebook": "https://facebook.com/lavacar"
      }
    }
  }
}

###

### Partial social links update — change only WhatsApp (Instagram and Facebook preserved)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_info": {
      "social_links": {
        "whatsapp": "11999999999"
      }
    }
  }
}

###

### Clear all social links
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_info": {
      "social_links": {
        "whatsapp": null,
        "instagram": null,
        "facebook": null
      }
    }
  }
}

###

### Full settings update (tenant rename is a separate endpoint — see tenant.http)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "loyalty": {
      "expiry_days": 180,
      "enable_notifications": true,
      "expiry_warning_days": 7
    },
    "booking": {
      "cancellation_window_hours": 48,
      "auto_approve_enabled": false,
      "min_booking_advance_hours": 2,
      "max_booking_advance_days": 60,
      "service_buffer_minutes": 30,
      "slot_granularity_minutes": 30
    },
    "business_hours": {
      "timezone": "America/Sao_Paulo",
      "monday": { "open": "08:00", "close": "18:00" },
      "tuesday": { "open": "08:00", "close": "18:00" },
      "wednesday": { "open": "08:00", "close": "18:00" },
      "thursday": { "open": "08:00", "close": "18:00" },
      "friday": { "open": "08:00", "close": "18:00" },
      "saturday": { "open": "09:00", "close": "14:00" },
      "sunday": null
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# ERROR CASES
# ─────────────────────────────────────────────────────────────────────────────

### 400 — Missing X-Tenant-ID header
PATCH {{baseUrl}}/tenants/settings
Content-Type: application/json

{
  "settings": { "loyalty": { "expiry_days": 90 } }
}

###

### 400 — cancellation_window_hours out of range (negative)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "booking": { "cancellation_window_hours": -1 }
  }
}

###

### 400 — Invalid IANA timezone
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_hours": { "timezone": "Not/AZone" }
  }
}

###

### 400 — slot_granularity_minutes not in [15, 30, 60]
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "booking": { "slot_granularity_minutes": 45 }
  }
}

###

### 400 — business_info.address.zip_code not 8 digits
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_info": {
      "address": {
        "street": "Av. Paulista",
        "number": "1000",
        "neighborhood": "Bela Vista",
        "city": "São Paulo",
        "state": "SP",
        "zip_code": "123"
      }
    }
  }
}

###

### 400 — business_info.phone not a valid phone number
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_info": { "phone": "123" }
  }
}

###

### 400 — business_info.email not a valid email address
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": {
    "business_info": { "email": "not-an-email" }
  }
}

###

### 400 — Empty body (settings field is required)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{}

###

### 400 — name provided instead of settings (moved to PATCH /tenants — see tenant.http)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "name": "Lavacar Novo Nome"
}

###

### 409 — Tenant is inactive (deactivated tenants cannot be modified)
# Replace with the ID of a deactivated tenant to test this case
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: 00000000-0000-4000-8000-000000009999
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: MANAGER
Content-Type: application/json

{
  "settings": { "loyalty": { "expiry_days": 90 } }
}

###

### 403 — CUSTOMER role not allowed (ManagerRoleGuard rejects)
PATCH {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{customerId}}
X-Actor-Type: CUSTOMER
X-Actor-Role: CUSTOMER
Content-Type: application/json

{
  "settings": { "loyalty": { "expiry_days": 90 } }
}

###

### 400 — Get: missing X-Tenant-ID header
GET {{baseUrl}}/tenants/settings
X-Actor-Role: MANAGER

###

### 403 — Get: STAFF role not allowed (ManagerRoleGuard rejects)
GET {{baseUrl}}/tenants/settings
X-Tenant-ID: {{tenantId}}
X-Actor-ID: {{managerId}}
X-Actor-Type: STAFF
X-Actor-Role: STAFF
