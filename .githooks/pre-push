#!/bin/bash
# pre-push hook: lint + prettier + type-check + backend/BFF unit tests.
# Web Vitest runs in CI via ci:integration.
# Skipped when every changed file relative to the remote tip is docs/tooling-only
# (*.md anywhere, or any file under td/, plan/, scripts/) — no app code changed.
# Activate: git config core.hooksPath .githooks
set -e

zero=$(git hash-object --stdin </dev/null | tr '[0-9a-f]' '0')
skip_pattern='(\.md$)|(^td/)|(^plan/)|(^scripts/)'
run_ci_fast=false

while read -r local_ref local_oid remote_ref remote_oid
do
  if [ "$local_oid" = "$zero" ]; then
    continue # branch deletion, nothing to check
  fi
  if [ "$remote_oid" = "$zero" ]; then
    run_ci_fast=true # new ref, no remote tip to diff against — safe default
    continue
  fi

  changed_files=$(git diff --name-only "$remote_oid" "$local_oid")
  if [ -n "$changed_files" ] && echo "$changed_files" | grep -qvE "$skip_pattern"; then
    run_ci_fast=true
  fi
done

if [ "$run_ci_fast" = false ]; then
  echo "pre-push: only docs/tooling changed (*.md, td/**, plan/**, scripts/**) — skipping ci:fast"
  exit 0
fi

pnpm ci:fast
