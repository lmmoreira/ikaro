#!/bin/bash
# pre-push hook: lint + prettier + type-check + backend/BFF unit tests.
# Web Vitest runs in CI via ci:integration.
# Skipped when every changed file relative to the diff base is docs/tooling-only
# (*.md anywhere, or any file under td/, plan/, scripts/, infra/terraform/,
# .agents/, .claude/, .copilot/, .github/, .githooks/) — no app code changed.
# Activate: git config core.hooksPath .githooks
# When testing skip_pattern changes interactively: use `command grep`, not a
# plain `grep` call — some interactive shells (e.g. Claude Code's own dev
# environment) alias grep to a wrapper with different -qvE behavior, which
# will silently give you the wrong answer for this exact pattern.
#
# Diff base: normally the branch's own remote tip. A brand-new branch has no
# remote tip yet (git passes an all-zero remote_oid) — that's a missing tip
# for *this ref*, not a missing base to diff against, so fall back to the
# merge-base with origin/main instead of skipping the diff outright. Worst
# case with a locally-stale origin/main is an over-broad diff that still
# runs ci:fast unnecessarily — same "safe default" direction as before,
# never the reverse (silently skipping when it shouldn't).
set -e

zero=$(git hash-object --stdin </dev/null | tr '[0-9a-f]' '0')
skip_pattern='(\.md$)|(^td/)|(^plan/)|(^scripts/)|(^infra/terraform/)|(^\.agents/)|(^\.claude/)|(^\.copilot/)|(^\.github/)|(^\.githooks/)'
run_ci_fast=false

while read -r local_ref local_oid remote_ref remote_oid
do
  if [ "$local_oid" = "$zero" ]; then
    continue # branch deletion, nothing to check
  fi

  if [ "$remote_oid" = "$zero" ]; then
    base=$(git merge-base "$local_oid" origin/main 2>/dev/null || echo "")
    if [ -z "$base" ]; then
      run_ci_fast=true # couldn't resolve a base — safe default, unchanged
      continue
    fi
  else
    base="$remote_oid"
  fi

  changed_files=$(git diff --name-only "$base" "$local_oid")
  if [ -n "$changed_files" ] && echo "$changed_files" | grep -qvE "$skip_pattern"; then
    run_ci_fast=true
  fi
done

if [ "$run_ci_fast" = false ]; then
  echo "pre-push: only docs/tooling changed (*.md, td/**, plan/**, scripts/**, infra/terraform/**, .agents/**, .claude/**, .copilot/**, .github/**, .githooks/**) — skipping ci:fast"
  exit 0
fi

pnpm ci:fast
