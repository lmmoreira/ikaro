#!/bin/bash
# pre-push hook — runs ci:fast scoped to changed apps only.
# Activate once with: git config core.hooksPath .githooks
set -e

# Compare against origin/main (all branches in this repo are cut from main).
# Fall back to HEAD~1 if origin/main isn't available yet (fresh clone, offline).
if git rev-parse --verify origin/main >/dev/null 2>&1; then
  CHANGED=$(git diff --name-only origin/main..HEAD 2>/dev/null || true)
else
  CHANGED=$(git diff --name-only HEAD~1..HEAD 2>/dev/null || true)
fi

[ -z "$CHANGED" ] && exit 0

# Classify changed files into affected scopes.
BACKEND=false BFF=false WEB=false ALL=false SKIP=true

while IFS= read -r f; do
  case "$f" in
    # Docs / CI config — no TypeScript impact
    *.md|*.txt|sonar-project.properties|.nvmrc|.npmrc) ;;
    docs/*|plan/*|td/*) ;;
    .github/*|*.yml|*.yaml) ;;
    # App-scoped
    apps/backend/*) BACKEND=true; SKIP=false ;;
    apps/bff/*)     BFF=true;     SKIP=false ;;
    apps/web/*)     WEB=true;     SKIP=false ;;
    # Shared packages or root deps → every app could be affected
    packages/*|package.json|pnpm-lock.yaml|pnpm-workspace.yaml) ALL=true; SKIP=false ;;
    # Unknown file — safe fallback: run everything
    *) ALL=true; SKIP=false ;;
  esac
done <<< "$CHANGED"

if $SKIP; then
  echo "✅ Docs/CI config only — skipping ci:fast"
  exit 0
fi

$ALL && BACKEND=true && BFF=true && WEB=true

echo "Running ci:fast (backend=$BACKEND bff=$BFF web=$WEB)..."

# Prettier — always fast, catches formatting in any file type
pnpm prettier --check .

# Lint — all affected apps in parallel (stateless, no contention)
LINT_FILTERS=()
$BACKEND && LINT_FILTERS+=(--filter @ikaro/backend)
$BFF     && LINT_FILTERS+=(--filter @ikaro/bff)
$WEB     && LINT_FILTERS+=(--filter @ikaro/web)
[ ${#LINT_FILTERS[@]} -gt 0 ] && pnpm "${LINT_FILTERS[@]}" --parallel run lint

# Type-check — all affected apps in parallel (stateless, no contention)
TYPE_CHECK_FILTERS=()
$BACKEND && TYPE_CHECK_FILTERS+=(--filter @ikaro/backend)
$BFF     && TYPE_CHECK_FILTERS+=(--filter @ikaro/bff)
$WEB     && TYPE_CHECK_FILTERS+=(--filter @ikaro/web)
[ ${#TYPE_CHECK_FILTERS[@]} -gt 0 ] && pnpm "${TYPE_CHECK_FILTERS[@]}" --parallel run type-check

# Unit tests — sequential: running multiple Jest/Vitest worker pools simultaneously
# causes CPU contention that produces flaky timeouts on a dev machine.
# Order: fastest first so failures surface quickly.
$BFF     && pnpm --filter @ikaro/bff     test
$WEB     && pnpm --filter @ikaro/web     test
$BACKEND && pnpm --filter @ikaro/backend test:unit
